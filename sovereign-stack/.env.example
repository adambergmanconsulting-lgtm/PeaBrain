# NadirClaw: copy to .env and set secrets. Prefix is always NADIR_

# === Optional: docker ensure (scripts/ensure-docker.js, same idea as CVReady) ===
# NADIR_DOCKER_ENSURE_SKIP=1
# NADIR_DOCKER_ENSURE_TIMEOUT_MS=120000

# === Cloud (OpenRouter) — required for cloud routing / escalation ===
NADIR_OPENROUTER_API_KEY=sk-or-REPLACE_ME

# Optional: header hints for OpenRouter
NADIR_OPENROUTER_REFERER=https://github.com/yourname/nadirclaw
NADIR_OPENROUTER_TITLE=NadirClaw-Home

# === Models (OpenRouter id + Ollama tag) ===
NADIR_LOCAL_MODEL=qwen2.5-coder:14b
NADIR_CLOUD_MODEL=anthropic/claude-3.5-sonnet

# === Routing: lines in primary file, multi_file, nadir.complex ===
NADIR_MAX_LINES_FOR_LOCAL=650
# When line count is missing: "cloud" (conservative) or "local" (saves $)
NADIR_ON_MISSING_METADATA=cloud
NADIR_USE_COMPLEXITY_FLAG=true
# true = always use Ollama for tools that cannot send `nadir` (e.g. Cursor). See CURSOR.md
NADIR_IDE_MODE=false
# Optional: CORS for browser/canvas clients (comma-separated, or * for dev only)
# NADIR_CORS_ORIGINS=*

# === Local base URL: in Docker, `docker-compose.yml` sets http://ollama:11434/v1 ===
# If Ollama runs on the host instead, point here (and remove the compose override for NADIR_LOCAL_BASE):
# NADIR_LOCAL_BASE=http://host.docker.internal:11434/v1

# === PeaBrain persona: web demo is hard-coded in demo/index.html; for `npm run chat` use: ===
# NADIR_CHAT_SYSTEM=You are PeaBrain…   (one line; or rely on default in scripts/lib/chat-defaults.mjs)
# Sampling (CLI chat only; browser demo uses query params, see below):
# Defaults match the web demo; omit these unless you want to tune the CLI.
# NADIR_CHAT_TEMPERATURE=0.6
# NADIR_CHAT_TOP_P=0.9
# NADIR_CHAT_MAX_TOKENS=1500

# === Prompt: strip comments/blank lines before sending to local (saves input tokens) ===
NADIR_MINIFY_LOCAL_MESSAGES=true

# === Verification: Prettier/ESLint on local outputs (self-correct once, then OpenRouter) ===
NADIR_VERIFY_WITH_ESLINT=true
NADIR_VERIFY_WITH_PRETTIER=true
NADIR_SELF_CORRECT_LOCAL_ONCE=true

# Timeouts (seconds)
NADIR_LOCAL_TIMEOUT_S=600
NADIR_CLOUD_TIMEOUT_S=600

# === PeaBrain demo: web search (server-side; keys are NOT in the browser) — optional ===
# Prefer one of: get a key from https://tavily.com or https://brave.com/search/api/
# NADIR_TAVILY_API_KEY=tvly-...
# Or: NADIR_BRAVE_SEARCH_API_KEY=BSA...
# NADIR_WEB_SEARCH_MAX_RESULTS=5
# Pasted-URL fetch limits (Nadir fetches the URL server-side; /api/demo/fetch-url)
# NADIR_DEMO_URL_FETCH_MAX_BYTES=1000000
# NADIR_DEMO_URL_FETCH_MAX_TEXT=32000

# === Public tunnel (see README "Public URL") — optional but recommended when the URL is on the public internet ===
# If set, Nadir requires Authorization: Bearer <this> for /v1/* (e.g. match Cursor "OpenAI API key"), except
# for Host 127.0.0.1/localhost/::1 when the next flag is true (so the local /demo/ works without pasting a token).
# NADIR_INBOUND_BEARER_TOKEN=your-long-random-string
# NADIR_INBOUND_BEARER_LOCALHOST_BYPASS=true

# Optional: for docker compose --profile ngrok (alternative to the built-in cloudflared quick tunnel)
# NGROK_AUTHTOKEN=
